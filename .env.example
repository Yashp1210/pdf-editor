# Neon Postgres connection string (do NOT commit your real one)
# Recommended to avoid future pg SSL-mode behavior changes:
# - sslmode=verify-full  (keeps strict verification)
# OR
# - uselibpqcompat=true&sslmode=require (libpq-compatible semantics)
# Example:
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=verify-full
DATABASE_URL=

# Express server port
PORT=3000

# JWT secret used for login cookie auth
# Use a long random string in production.
AUTH_JWT_SECRET=

# If set, auth endpoints will only accept requests with Origin/Referer matching this.
# Example: https://your-domain.com
PUBLIC_ORIGIN=

# Enforce encrypted payloads (x-enc=1) for auth + core APIs.
# Set to 0 only for troubleshooting.
REQUIRE_ENCRYPTED_PAYLOADS=1
