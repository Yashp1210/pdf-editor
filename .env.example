# Example environment variables for PDF Editor (Express + Vite)
# Copy to .env for local dev OR set these in Render dashboard.
# Never commit real secrets.

# Neon Postgres connection string
DATABASE_URL=

# Express server port (Render sets PORT automatically in production)
PORT=3000

# JWT secret used for login cookie auth (REQUIRED in production)
AUTH_JWT_SECRET=

# Allowed browser origin (set this to your production URL)
# Example: https://pdf-editor.inlasthour.com
PUBLIC_ORIGIN=

# Cloudflare Turnstile (captcha)
# Frontend (Vite) site key:
VITE_TURNSTILE_SITE_KEY=
# Server secret key:
TURNSTILE_SECRET_KEY=

# Enforce encrypted payloads (x-enc=1) for auth + core APIs.
REQUIRE_ENCRYPTED_PAYLOADS=1

# --- Proof-of-Possession (PoP) anti-replay signatures
# If 1, core /api/* calls require a browser-held signing key + one-time nonce.
REQUIRE_POP_SIGNATURES=1
# Nonce lifetime (single-use) in ms
POP_NONCE_TTL_MS=60000

# --- Rate limiting (basic app-level DoS protection)
API_RATE_WINDOW_MS=60000
API_RATE_LIMIT=60
AUTH_RATE_WINDOW_MS=900000
AUTH_RATE_LIMIT=20

# Login brute-force protection (credential stuffing)
LOGIN_RATE_WINDOW_MS=600000
LOGIN_RATE_LIMIT=10

# Cap how many login requests are processed concurrently (extra protection under floods)
LOGIN_MAX_CONCURRENT=10

# Max raw request body size allowed for auth endpoints (bytes)
AUTH_MAX_BODY_BYTES=16384

# --- Reverse proxy / Cloudflare
# If you deploy behind Cloudflare, enable `trust proxy` in production (server default does this).
# Optionally enforce that API requests must pass through Cloudflare by requiring CF headers.
REQUIRE_CLOUDFLARE=0

# --- Request size / timeout hardening
# This app's API bodies should be small; keep this low.
JSON_BODY_LIMIT=256kb
HTTP_KEEP_ALIVE_TIMEOUT_MS=5000
HTTP_HEADERS_TIMEOUT_MS=10000
HTTP_REQUEST_TIMEOUT_MS=30000
